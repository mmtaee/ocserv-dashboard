# ---------------------------------------------------------------
# OCServ Dashboard Full Configuration File
# ---------------------------------------------------------------
# 1. Copy this file to create your own .env file:
#       cp .env.sample .env
# 2. Edit the values to match your environment.
# 3. Use this .env file with:
#       - Docker Compose: Automatically loaded if .env is in root
#       - Systemd: Source from config files in deploy/systemd/config
# ---------------------------------------------------------------

# ==============================================
# General System Configuration
# ==============================================
# Server host or IP address (public address where the services will be accessible from)
HOST=127.0.0.1
# Secret key for internal API/auth usage
SECRET_KEY=your-strong-secret-key-change-this-in-production
# JWT secret used by APIs for authentication
JWT_SECRET=your-strong-jwt-secret-change-this-in-production
# Supported languages (format: code:Name, comma-separated)
LANGUAGES=en:English,zh:中文,ru:Русский,fa:فارسی,ar:العربية
# Allowed CORS origins (comma-separated)
ALLOW_ORIGINS="https://${HOST}:3443,http://${HOST}:3000,http://localhost:3000,http://localhost:5173"

# ==============================================
# Database (PostgreSQL) Configuration
# ==============================================
# PostgreSQL host (in Docker, this is the service name; in systemd: localhost)
POSTGRES_HOST=ocserv-postgres
# PostgreSQL port
POSTGRES_PORT=5432
# PostgreSQL database name
POSTGRES_DB=ocserv
# PostgreSQL username
POSTGRES_USER=ocserv
# PostgreSQL password (set a strong password here)
POSTGRES_PASSWORD=your-strong-postgres-password-change-this-in-production
# PostgreSQL SSL mode (disable, require, verify-ca, verify-full)
POSTGRES_SSLMODE=disable
# PostgreSQL data volume path (for persistence)
POSTGRES_DATA_PATH=./data/postgres

# ==============================================
# Ocserv VPN Server Configuration
# ==============================================
# Ocserv listening port
OCSERV_PORT=443
# Ocserv VPN subnet (CIDR format)
OC_NET=172.16.24.0/24
# Ocserv DNS server for clients
OCSERV_DNS=8.8.8.8,8.8.4.4
# SSL certificate Common Name (usually your domain or public IP)
SSL_CN=End-way-Cisco-VPN
# SSL certificate Organization Name
SSL_ORG=End-way
# SSL certificate validity in days
SSL_EXPIRE=3650
# Ocserv pre-login banner
OCSERV_PRE_LOGIN_BANNER="Welcome to Ocserv VPN"
# Ocserv welcome banner
OCSERV_BANNER="Welcome to Ocserv VPN!"
# Ocserv version (optional)
OCSERV_VERSION=1.3.0

# ==============================================
# Services configuration
# ===============================
# Admin Dashboard API
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8080
ADMIN_API_DEBUG=false

# Customer Dashboard API
CUSTOMER_API_HOST=0.0.0.0
CUSTOMER_API_PORT=8081
CUSTOMER_API_DEBUG=false

# Ocserv User Manager
USER_MANAGER_DEBUG=false

# Ocserv Log Parser
LOG_PARSER_HOST=0.0.0.0
LOG_PARSER_PORT=8082
LOG_PARSER_DEBUG=false
LOG_PARSER_DOCKER_MODE=false

# Ocserv Telegram Bot
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_DEBUG=false
TELEGRAM_API_BASE=https://api.telegram.org

# ==============================================
# UI Configuration
# ==============================================
# Admin Dashboard UI port (for Nginx and Docker)
ADMIN_UI_PORT=3004
# Customer Dashboard UI port
CUSTOMER_UI_PORT=3005

# ==============================================
# Optional Mirror Configurations (for development only)
# ==============================================
# Go module proxy (e.g., https://goproxy.cn)
GO_PROXY=
# NPM registry mirror (e.g., https://registry.npmmirror.com)
NPM_REGISTRY=
# Debian apt mirror (e.g., http://deb.debian.org)
DEBIAN_MIRROR=
# Debian security apt mirror
DEBIAN_SECURITY_MIRROR=

# ==============================================
# Optional: Telegram Receipts Directory
# ==============================================
# Directory for storing receipt uploads
TELEGRAM_RECEIPTS_DIR=/opt/ocserv_dashboard/uploads/receipts
CURRENT_RELEASE=v4.9
LATEST_RELEASE=v4.9
