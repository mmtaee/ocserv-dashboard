    "backend": {
      "language": "Go 1.25+",
      "framework": "Echo v5",
      "orm": "GORM",
      "database": "PostgreSQL",
      "migrations": "Gormigrate v2",
      "validation": "Validator v10",
      "cli": "Cobra"
    },
    "frontend": {
      "framework": "Vue 3",
      "buildTool": "Vite",
      "ui": "Custom components"
    },
    "infrastructure": {
      "containerization": ["Docker", "Docker Compose"],
      "deploymentOptions": ["Docker-based", "Systemd-based"],
