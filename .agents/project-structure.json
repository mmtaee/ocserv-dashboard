{
  "name": "Ocserv Dashboard",
  "overview": "A web-based dashboard to manage an OpenConnect VPN server (ocserv), including user/group management, monitoring, statistics, and an integrated Telegram bot for customer self-service.",
  "techStack": {
    "backend": {
      "language": "Go 1.25+",
      "framework": "Echo v5",
      "orm": "GORM",
      "database": "PostgreSQL",
      "migrations": "Gormigrate v2",
      "validation": "Validator v10",
      "cli": "Cobra"
    },
    "frontend": {
      "framework": "Vue 3",
      "ui": "Vuetify",
      "buildTool": "Vite",
      "router": "Vue Router 4",
      "state": "Pinia",
      "i18n": "Vue I18n"
    },
    "infrastructure": {
      "containerization": ["Docker", "Docker Compose"],
      "deploymentOptions": ["All-in-one Docker", "Systemd"],
      "supportedOs": ["Debian 12+", "Ubuntu 20.04+"]
    }
  },
